/* Exemplo de Listas (Arrays Dinâmicos) */
escrever("=== LISTAS ===")

var frutas = ["maçã", "banana", "laranja"]
escrever("Frutas:", tamanho(frutas), "itens")
escrever("Primeira:", frutas[0])

lista_adicionar(frutas, "uva")
escrever("Após adicionar uva:", tamanho(frutas))

/* Laço sobre lista */
var i = 0
enquanto (i < tamanho(frutas)) {
    escrever("-", frutas[i])
    i = i + 1
}

/* Lista de números com para-de-ate */
var numeros = [10, 20, 30, 40, 50]
var soma = 0
para k de 0 ate 4 {
    soma = soma + numeros[k]
}
escrever("Soma dos números:", soma)
